@startuml c4_container
!theme plain
!include <C4/C4_Container>

title Playwright Test Generation — Container Diagram

Person(dev, "Developer", "Constructs models,\ncalls generation API")

System_Boundary(codegen, "CodeGenerator Framework") {
    Container(core, "CodeGenerator.Core", "C# / .NET", "Syntax & Artifact engines,\nstrategy dispatch, DI,\nnaming conventions")
    Container(pw, "CodeGenerator.Playwright", "C# / .NET", "Playwright-specific models,\nsyntax strategies,\nproject scaffolding")
}

System_Ext(fs, "File System", "Generated TypeScript\nproject output")
System_Ext(npm, "Node.js / npm", "Package installation")

Rel(dev, pw, "Creates models,\ncalls factories", "C# API")
Rel(pw, core, "Uses ISyntaxGenerator,\nIArtifactGenerator", "Assembly ref")
Rel(pw, fs, "Writes .ts, .json files")
Rel(pw, npm, "npm init, npm install")

@enduml
