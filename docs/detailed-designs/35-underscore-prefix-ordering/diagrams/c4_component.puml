@startuml c4_component
!theme plain
!include <C4/C4_Component>

title Underscore-Prefix Ordering - Component Diagram

Container_Boundary(convention, "Convention-Based Generation") {
    Component(strategy, "ConventionBasedStrategy", "Core", "Discovers and partitions templates")
    Component(partitioner, "TemplatePartitioner", "Internal", "Separates regular and underscore-prefixed")
}

Component(gen_context, "IGenerationContext", "Core", "Tracks generated files")
Component(tmpl_processor, "ITemplateProcessor", "Core", "Renders DotLiquid templates")
Component(artifact_gen, "IArtifactGenerator", "Core", "Writes output files")

Rel(strategy, partitioner, "Partitions templates")
Rel(strategy, tmpl_processor, "Renders templates")
Rel(strategy, gen_context, "Reads GeneratedFiles")
Rel(strategy, artifact_gen, "Writes files")

@enduml
