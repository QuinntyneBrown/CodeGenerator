@startuml sequence_discovery
!theme plain
skinparam sequenceMessageAlign center

title Strategy Discovery and Metadata Loading

participant "DI Container" as di
participant "ConventionStrategy" as strat
participant "TemplateSetInfoLoader" as loader
database "File System" as fs

di -> strat : Construct(loader)
activate strat
strat --> di : instance
deactivate strat

strat -> loader : Load("Templates/DotNet/WebApi")
activate loader
loader -> fs : ReadAllText("_templateinfo.json")
fs --> loader : JSON content
loader -> loader : Deserialize to TemplateSetInfo
loader -> loader : Cache result
loader --> strat : TemplateSetInfo(Priority=10)
deactivate loader

strat -> loader : Load("Templates/DotNet/WebApi")
activate loader
loader -> loader : Return from cache
loader --> strat : TemplateSetInfo(Priority=10)
deactivate loader

@enduml
