@startuml class_diagram
!theme plain

title SKILL.md — Documented Model Surface per Module

package "CodeGenerator.DotNet" {
    class SolutionModel {
        +Name: string
        +SolutionDirectory: string
        +Projects: List<ProjectModel>
    }
    class ProjectModel {
        +Name: string
        +DotNetProjectType: enum
        +Files: List<FileModel>
        +Packages: List<PackageModel>
    }
    class ClassModel {
        +Name: string
        +Properties: List<PropertyModel>
        +Methods: List<MethodModel>
        +Constructors: List<ConstructorModel>
    }
    class EntityModel {
        +AggregateRootName: string
        +CreateDto(): ClassModel
    }
    class InterfaceModel {
        +Name: string
        +Implements: List<TypeModel>
    }
    note "Also: ControllerModel, DbContextModel,\nFullStackModel, 27+ template categories,\nISolutionFactory, IClassFactory,\nIEntityFactory, ICqrsFactory" as N1
}

