@startuml c4_context
!theme plain
!include <C4/C4_Context>

title Centralized Dependency Management — System Context

Person(dev, "Developer", "Configures target framework and generates code")

System(codegen, "CodeGenerator", "Multi-framework code generation engine with centralized dependency version resolution")

System_Ext(nuget, "NuGet Registry", "Source of .NET package version information")
System_Ext(npm, "npm Registry", "Source of Node.js package version information")
System_Ext(pypi, "PyPI Registry", "Source of Python package version information")
System_Ext(fs, "File System", "Generated project files with resolved dependency versions")

Rel(dev, codegen, "Invokes generation with target framework")
Rel(codegen, fs, "Writes project files with correct package versions")
Rel_L(nuget, codegen, "Versions captured in manifests")
Rel_L(npm, codegen, "Versions captured in manifests")
Rel_L(pypi, codegen, "Versions captured in manifests")

@enduml
