@startuml c4_context
!theme plain
!include <C4/C4_Context>

title Telemetry and Diagnostics — System Context

Person(dev, "Developer / Support", "Runs generation with --diagnostics to collect environment and timing data")

System(codegen, "CodeGenerator CLI", "Code generation engine with built-in diagnostics collection")

System_Ext(sdk, ".NET SDK", "Queried for version information")
System_Ext(os, "Operating System", "Queried for OS, architecture, shell info")

Rel(dev, codegen, "codegen -n Foo --diagnostics")
Rel(codegen, sdk, "dotnet --version")
Rel(codegen, os, "RuntimeInformation queries")
Rel(codegen, dev, "Diagnostics report\n(environment + per-step timing)")

@enduml
