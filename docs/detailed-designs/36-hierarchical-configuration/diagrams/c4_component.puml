@startuml c4_component
!theme plain
!include <C4/C4_Component>

title Hierarchical Configuration - Component Diagram

Container_Boundary(config_system, "Configuration System") {
    Component(iconfig, "ICodeGeneratorConfiguration", "Abstractions", "Read-only config interface")
    Component(config_impl, "CodeGeneratorConfiguration", "Core", "Merges four config tiers")
    Component(locator, "ConfigFileLocator", "Core", "Finds .codegenerator.json")
    Component(env_mapper, "EnvironmentVariableMapper", "Core", "Maps CODEGEN_* env vars")
}

Component(cli, "ScaffoldCommand", "CLI", "CLI overrides")
Component(strategy, "Strategies", "Core", "Config consumers")

Rel(config_impl, iconfig, "Implements")
Rel(config_impl, locator, "Finds config file")
Rel(config_impl, env_mapper, "Reads env vars")
Rel(cli, config_impl, "Passes CLI args")
Rel(strategy, iconfig, "GetValue()")

@enduml
