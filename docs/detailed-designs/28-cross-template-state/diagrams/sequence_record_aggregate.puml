@startuml sequence_record_aggregate
!theme plain
skinparam sequenceMessageAlign center

title Strategy Records File then Post-Processor Reads Context

participant "ArtifactGenerator" as ag
participant "ClassFileStrategy" as strat1
participant "IGenerationContext" as ctx
participant "CsprojPostStrategy" as postStrat
database "File System" as fs

ag -> strat1 : GenerateAsync(classModel)
activate strat1
strat1 -> fs : Write Order.cs
strat1 -> ctx : RecordGeneratedFile("Order.cs")
deactivate strat1

ag -> strat1 : GenerateAsync(classModel)
activate strat1
strat1 -> fs : Write Customer.cs
strat1 -> ctx : RecordGeneratedFile("Customer.cs")
deactivate strat1

ag -> postStrat : GenerateAsync(solutionModel)
activate postStrat
postStrat -> ctx : GeneratedFiles
ctx --> postStrat : [Order.cs, Customer.cs]
postStrat -> fs : Update .csproj with entries
deactivate postStrat

@enduml
