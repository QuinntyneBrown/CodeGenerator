@startuml sequence_duplicate_prevention
!theme plain
skinparam sequenceMessageAlign center

title Duplicate Prevention via Resource Tracking

participant "ArtifactGenerator" as ag
participant "StrategyA\n(Priority=10)" as stratA
participant "StrategyB\n(Priority=1)" as stratB
participant "IGenerationContext" as ctx
database "File System" as fs

ag -> stratA : CanHandle(classModel)
activate stratA
stratA -> ctx : IsHandled("UserController")
ctx --> stratA : false
stratA --> ag : true
deactivate stratA

ag -> stratA : GenerateAsync(userController)
activate stratA
stratA -> fs : Write UserController.cs
stratA -> ctx : MarkHandled("UserController", "StrategyA")
deactivate stratA

== Later: same model dispatched again ==

ag -> stratA : CanHandle(classModel)
activate stratA
stratA -> ctx : IsHandled("UserController")
ctx --> stratA : true
stratA --> ag : false (skip)
deactivate stratA

ag -> stratB : CanHandle(classModel)
activate stratB
stratB -> ctx : IsHandled("UserController")
ctx --> stratB : true
stratB --> ag : false (skip)
deactivate stratB

@enduml
