@startuml sequence_duplicate_prevention
!theme plain
skinparam sequenceMessageAlign center

title Duplicate Prevention — Strategy A Handles, Strategy B Skips

participant "ArtifactGenerator" as ag
participant "ControllerGeneration\nStrategy (Priority=10)" as stratA
participant "GenericClassGeneration\nStrategy (Priority=1)" as stratB
participant "IGenerationContext" as ctx
participant "ILogger" as log
database "File System" as fs

[-> ag : GenerateAsync(ClassModel "UserController")
activate ag

ag -> stratA : CanHandle(classModel)
activate stratA
stratA -> ctx : IsHandled("ClassModel:UserController")
ctx --> stratA : false
stratA --> ag : true
deactivate stratA

ag -> stratA : GenerateAsync(userController)
activate stratA
stratA -> fs : Write UserController.cs
stratA -> ctx : MarkHandled(\n  "ClassModel:UserController",\n  "ControllerGenerationStrategy")
ctx -> log : Debug: "Resource marked as handled"
stratA -> ctx : RecordGeneratedFile(...)
deactivate stratA

ag --> [
deactivate ag

== Second pass or multi-strategy dispatch ==

[-> ag : GenerateAsync(ClassModel "UserController")
activate ag

ag -> stratA : CanHandle(classModel)
activate stratA
stratA -> ctx : IsHandled("ClassModel:UserController")
ctx --> stratA : true
stratA -> log : Info: "Skipping: already handled\nby ControllerGenerationStrategy"
stratA --> ag : false
deactivate stratA

ag -> stratB : CanHandle(classModel)
activate stratB
stratB -> ctx : IsHandled("ClassModel:UserController")
ctx --> stratB : true
stratB -> log : Info: "Skipping: already handled"
stratB --> ag : false
deactivate stratB

ag --> [ : No strategy available (already handled)
deactivate ag

@enduml
