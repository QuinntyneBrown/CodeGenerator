@startuml c4_container
!theme plain
!include <C4/C4_Container>

title C4 Container — Input Validation Layer

Person(user, "CLI User")

System_Boundary(codegen, "CodeGenerator") {
    Container(cli, "CodeGenerator.Cli", ".NET Console App", "GenerationOptions, GenerationOptionsValidator, command handler integration")
    Container(abstractions, "CodeGenerator.Abstractions", ".NET Class Library", "ValidationResult, ValidationError, ValidationSeverity")
    Container(core, "CodeGenerator.Core", ".NET Class Library", "Generation engine (invoked only after validation passes)")
}

System_Ext(fs, "File System")

Rel(user, cli, "Invokes")
Rel(cli, abstractions, "Uses ValidationResult types")
Rel(cli, core, "Invokes generation after validation")
Rel(cli, fs, "Checks directory via IFileSystem")

@enduml
