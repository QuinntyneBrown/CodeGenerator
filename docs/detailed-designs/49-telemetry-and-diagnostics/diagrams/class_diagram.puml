@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontSize 12

title Telemetry and Diagnostics - Domain Model

interface IGenerationTimer {
    +TimeStep(stepName: string): IDisposable
    +GetEntries(): IReadOnlyList<TimingEntry>
    +TotalElapsed: TimeSpan
}

class GenerationTimer {
    -_entries: ConcurrentBag<TimingEntry>
    -_order: int
    -_totalStopwatch: Stopwatch
    +TimeStep(stepName): IDisposable
    +GetEntries(): IReadOnlyList<TimingEntry>
    +TotalElapsed: TimeSpan
}

class NullGenerationTimer {
    +TimeStep(stepName): IDisposable
    +GetEntries(): IReadOnlyList<TimingEntry>
    +TotalElapsed: TimeSpan
}

class TimingEntry <<record>> {
    +StepName: string
    +Duration: TimeSpan
    +Order: int
}

class DiagnosticsCollector {
    +CollectEnvironment(cliVersion: string): EnvironmentInfo
}

class EnvironmentInfo <<record>> {
    +CliVersion: string
    +DotNetSdkVersion: string
    +RuntimeVersion: string
    +OperatingSystem: string
    +Architecture: string
    +Shell: string
    +WorkingDirectory: string
}

class DiagnosticsReport {
    +Environment: EnvironmentInfo
    +Steps: List<TimingEntry>
    +TotalDuration: TimeSpan
    +GeneratedAt: DateTime
}

class DiagnosticsRenderer {
    -_console: IAnsiConsole
    +Render(report: DiagnosticsReport): void
}

IGenerationTimer <|.. GenerationTimer
IGenerationTimer <|.. NullGenerationTimer
GenerationTimer --> TimingEntry : produces
DiagnosticsCollector --> EnvironmentInfo : creates
DiagnosticsReport *-- EnvironmentInfo
DiagnosticsReport *-- "0..*" TimingEntry
DiagnosticsRenderer --> DiagnosticsReport : renders

@enduml
