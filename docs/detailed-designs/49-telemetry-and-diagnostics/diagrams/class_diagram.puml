@startuml class_diagram
!theme plain
skinparam classAttributeIconSize 0
skinparam classFontSize 12

title Telemetry and Diagnostics — Class Diagram

class DiagnosticsCollector {
    -_commandService : ICommandService
    +CollectEnvironment() : EnvironmentInfo
    -GetSdkVersion() : string
    -GetShell() : string
}

class EnvironmentInfo <<record>> {
    +CliVersion : string
    +DotNetSdkVersion : string
    +RuntimeVersion : string
    +OperatingSystem : string
    +Architecture : string
    +Shell : string
    +WorkingDirectory : string
}

interface IStopwatchProvider {
    +StartNew() : IStopwatchInstance
}

interface IStopwatchInstance {
    +Elapsed : TimeSpan {get}
    +Stop() : void
}

class SystemStopwatchProvider {
    +StartNew() : IStopwatchInstance
}

class NullStopwatchProvider {
    +StartNew() : IStopwatchInstance
}

class GenerationTimer {
    -_stopwatchProvider : IStopwatchProvider
    -_entries : ConcurrentBag<TimingEntry>
    -_order : int
    +TimeStep(stepName: string) : IDisposable
    +GetEntries() : IReadOnlyList<TimingEntry>
    +TotalElapsed : TimeSpan {get}
}

class TimingScope <<internal>> {
    -_stepName : string
    -_stopwatch : IStopwatchInstance
    -_timer : GenerationTimer
    -_order : int
    +Dispose() : void
}

class TimingEntry <<record>> {
    +StepName : string
    +Duration : TimeSpan
    +Order : int
}

class DiagnosticsReport <<record>> {
    +Environment : EnvironmentInfo
    +Steps : IReadOnlyList<TimingEntry>
    +TotalDuration : TimeSpan
    +GeneratedAt : DateTime
}

class DiagnosticsRenderer {
    +Render(report: DiagnosticsReport) : void
    -FormatDuration(ts: TimeSpan) : string
    -PadWithDots(name: string, width: int) : string
}

IStopwatchProvider <|.. SystemStopwatchProvider
IStopwatchProvider <|.. NullStopwatchProvider
IStopwatchProvider ..> IStopwatchInstance : creates
GenerationTimer --> IStopwatchProvider : uses
GenerationTimer --> "0..*" TimingEntry : records
GenerationTimer ..> TimingScope : creates
TimingScope ..> IStopwatchInstance : wraps
DiagnosticsCollector --> EnvironmentInfo : produces
DiagnosticsReport *-- EnvironmentInfo
DiagnosticsReport *-- "0..*" TimingEntry
DiagnosticsRenderer --> DiagnosticsReport : renders

@enduml
