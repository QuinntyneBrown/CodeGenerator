@startuml c4_component
!theme plain
!include <C4/C4_Component>

title Telemetry and Diagnostics - Component Diagram

Container_Boundary(core, "CodeGenerator.Core.Diagnostics") {
    Component(iTimer, "IGenerationTimer", "Interface", "TimeStep, GetEntries, TotalElapsed")
    Component(timer, "GenerationTimer", "C#", "Real stopwatch timing")
    Component(nullTimer, "NullGenerationTimer", "C#", "No-op when --diagnostics off")
    Component(collector, "DiagnosticsCollector", "C#", "Reads RuntimeInformation, env vars")
    Component(report, "DiagnosticsReport", "Record", "Environment + Steps + TotalDuration")
    Component(envInfo, "EnvironmentInfo", "Record", "CLI version, SDK, OS, arch, shell")
    Component(entry, "TimingEntry", "Record", "StepName, Duration, Order")
}

Container_Boundary(cli, "CodeGenerator.Cli") {
    Component(createCmd, "CreateCodeGeneratorCommand", "C#", "Wraps steps, renders report")
    Component(scaffoldCmd, "ScaffoldCommand", "C#", "Wraps steps, renders report")
    Component(renderer, "DiagnosticsRenderer", "Spectre.Console", "Tables with duration bars")
}

iTimer <|.. timer
iTimer <|.. nullTimer
timer --> entry : produces
collector --> envInfo : produces
report --> envInfo : contains
report --> entry : contains
createCmd --> iTimer : TimeStep()
createCmd --> collector : CollectEnvironment()
createCmd --> renderer : Render(report)
scaffoldCmd --> iTimer : TimeStep()
renderer --> report : reads

@enduml
