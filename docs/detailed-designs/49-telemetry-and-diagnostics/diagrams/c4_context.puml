@startuml c4_context
!theme plain
!include <C4/C4_Context>

title Telemetry and Diagnostics - System Context

Person(user, "CLI User", "Runs commands with --diagnostics")

System(cli, "CodeGenerator CLI", "Code generation with optional diagnostics output")
System_Ext(runtime, ".NET Runtime", "Provides version, OS, architecture info")

Rel(user, cli, "create-code-cli --diagnostics")
Rel(cli, runtime, "Reads RuntimeInformation")
Rel(cli, user, "Renders timing table\nand environment info")

@enduml
