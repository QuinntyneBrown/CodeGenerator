@startuml c4_container
!theme plain
!include <C4/C4_Container>

title Telemetry and Diagnostics - Container Diagram

Person(user, "CLI User", "Passes --diagnostics flag")

System_Boundary(sb, "CodeGenerator CLI") {
    Container(cmd, "Commands", "System.CommandLine", "Wraps steps in timer.TimeStep()")
    Container(timer, "GenerationTimer", "C#", "Stopwatch-based per-step timing")
    Container(collector, "DiagnosticsCollector", "C#", "Gathers environment info")
    Container(renderer, "DiagnosticsRenderer", "Spectre.Console", "Formats report as tables")
}

Rel(user, cmd, "--diagnostics flag")
Rel(cmd, timer, "TimeStep() per step")
Rel(cmd, collector, "CollectEnvironment()")
Rel(cmd, renderer, "Render(report)")
Rel(renderer, user, "Formatted table output")

@enduml
