@startuml sequence_diagnostics
!theme plain
skinparam sequenceMessageAlign center

title Generation with --diagnostics Enabled

actor User
participant "CreateCodeGeneratorCommand" as CMD
participant "GenerationTimer" as GT
participant "IArtifactGenerator" as AG
participant "ICommandService" as CS
participant "DiagnosticsCollector" as DC
participant "DiagnosticsRenderer" as DR

User -> CMD: HandleAsync(name, ..., diagnostics=true)
CMD -> GT: new GenerationTimer()

CMD -> GT: TimeStep("Validate options")
GT --> CMD: IDisposable scope
CMD -> CMD: validator.Validate(options)
CMD -> CMD: scope.Dispose()

CMD -> GT: TimeStep("Create directories")
GT --> CMD: scope
CMD -> CMD: Directory.CreateDirectory(...)
CMD -> CMD: scope.Dispose()

CMD -> GT: TimeStep("Create solution file")
GT --> CMD: scope
CMD -> CS: Start("dotnet new sln")
CMD -> CMD: scope.Dispose()

CMD -> GT: TimeStep("Generate project files")
GT --> CMD: scope
CMD -> AG: GenerateAsync(.csproj)
CMD -> AG: GenerateAsync(Program.cs)
CMD -> CMD: scope.Dispose()

CMD -> GT: TimeStep("Add project to solution")
GT --> CMD: scope
CMD -> CS: Start("dotnet sln add")
CMD -> CMD: scope.Dispose()

CMD -> DC: CollectEnvironment("1.2.0")
DC --> CMD: EnvironmentInfo

CMD -> CMD: Build DiagnosticsReport\n(env + timer.GetEntries())

CMD -> DR: Render(report)
DR --> User: Formatted timing table\nand environment info

@enduml
