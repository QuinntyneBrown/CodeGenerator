@startuml sequence_export_schema
!theme plain
skinparam sequenceMessageAlign center

title Export Schema Workflow

actor Developer as dev
participant "ScaffoldCommand" as cmd
participant "ISchemaExporter" as exporter
participant "IFileSystem" as fsys

dev -> cmd : codegen scaffold\n--export-schema
activate cmd

cmd -> exporter : ExportJsonSchema()
activate exporter
exporter --> cmd : jsonSchemaString
deactivate exporter

cmd -> fsys : WriteAllTextAsync(path, schema)
fsys --> cmd : done
cmd --> dev : Schema written

deactivate cmd

note over dev, fsys
  --init flag works similarly:
  calls GenerateStarterYaml()
  and writes scaffold.yaml
end note

@enduml
