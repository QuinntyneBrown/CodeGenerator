@startuml c4_context
!theme plain
!include <C4/C4_Context>

title Angular Generation — System Context

Person(dev, "Developer", "Builds models describing\nAngular workspaces and projects")
System(codegen, "CodeGenerator.Angular", "Generates Angular workspaces\nwith Jest, standalone components,\nNGRx, and TypeScript artifacts")
System_Ext(hostApp, "Host Application", "CLI or API that constructs\nmodels and invokes generation")
System_Ext(fs, "File System", "Reads/writes generated\nTypeScript, JSON, SCSS files")
System_Ext(node, "Node.js / npm", "Package manager for\ninstalling Angular dependencies")
System_Ext(ngcli, "Angular CLI", "Scaffolds workspaces\nand projects via ng commands")

Rel(dev, hostApp, "Configures generation")
Rel(hostApp, codegen, "Passes WorkspaceModel /\nProjectModel")
Rel(codegen, fs, "Writes generated files")
Rel(codegen, node, "npm install / uninstall")
Rel(codegen, ngcli, "ng new / ng generate")

@enduml
