@startuml c4_component
!theme plain
!include <C4/C4_Component>

title Input Validation with JSON Schema - Component Diagram

Container_Boundary(validation, "Validation System") {
    Component(ivalidator, "IInputValidator", "Abstractions", "Validates structured input")
    Component(validator_impl, "JsonSchemaInputValidator", "Core", "JSON Schema validation")
    Component(registry, "SchemaRegistry", "Core", "Loads and caches schemas")
}

Component(scaffold_schema, "scaffold-config.schema.json", "Embedded", "YAML config schema")
Component(engine, "ScaffoldEngine", "Core", "Pre-generation validation")
Component(cli, "ScaffoldCommand", "CLI", "Validate flag")

Rel(validator_impl, ivalidator, "Implements")
Rel(validator_impl, registry, "Loads schema")
Rel(registry, scaffold_schema, "Reads embedded resource")
Rel(engine, ivalidator, "ValidateInput()")
Rel(cli, ivalidator, "ValidateInput()")

@enduml
