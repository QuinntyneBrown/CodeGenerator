{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "InMemory"
  },
  "Jwt": {
    "Issuer": "{{Name}}",
    "Audience": "{{Name}}",
    "SigningKey": "{{JwtSigningKey}}",
    "AccessTokenMinutes": 60
  }
}
